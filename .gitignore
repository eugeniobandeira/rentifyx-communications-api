*.pfx
*.p12
*.key
*.pem
/secrets/
/.secrets/

# ─── Terraform ──────────────────────────────────────────────────────────────
# Note: actual Terraform files live under iac/terraform/, not iac/ directly -
# .terraform/ (bare, no path prefix) matches at any depth, unlike iac/.terraform/
# which only matched a literal iac/.terraform/ that never existed.
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!terraform.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── JetBrains Rider ────────────────────────────────────────────────────────
.idea/
*.sln.iml

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

