<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "https://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="color-scheme" content="light" />
  <title>RentifyX</title>
  <!--[if gte mso 9]>
  <xml><o:OfficeDocumentSettings><o:AllowPNG/><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  <![endif]-->
  <style>
    body, table, td { font-family: Arial, Helvetica, sans-serif; }
    body { margin: 0; padding: 0; width: 100% !important; background-color: #f8fafc; }
    table { border-collapse: collapse; }
    img { border: 0; -ms-interpolation-mode: bicubic; }
    a { text-decoration: none; }
    @media screen and (max-width: 600px) {
      .email-container { width: 100% !important; }
      .mobile-px-24 { padding-left: 24px !important; padding-right: 24px !important; }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#f8fafc;">
  <center role="article" aria-roledescription="email" style="width:100%; background-color:#f8fafc;">
    <!--[if mso]>
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" align="center"><tr><td>
    <![endif]-->
    <div class="email-container" style="max-width:600px; margin:0 auto;">

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 auto;">
        <tr>
          <td style="background-color:#2563eb; padding:28px 40px; border-radius:8px 8px 0 0;" class="mobile-px-24">
            <span style="font-family:Arial, Helvetica, sans-serif; font-size:22px; font-weight:bold; color:#ffffff; letter-spacing:0.3px;">RentifyX</span>
          </td>
        </tr>

        <tr>
          <td style="background-color:#ffffff; padding:40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0;" class="mobile-px-24">
            <p style="margin:0 0 16px 0; font-family:Arial, Helvetica, sans-serif; font-size:20px; line-height:28px; color:#0f172a; font-weight:bold;">Confirm your email</p>
            <p style="margin:0 0 24px 0; font-family:Arial, Helvetica, sans-serif; font-size:15px; line-height:24px; color:#475569;">
              Thanks for signing up with RentifyX. Confirm your email address to activate your account.
            </p>
            <table role="presentation" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="border-radius:6px; background-color:#2563eb;">
                  <a href="https://app.rentifyx.com/verify-email?token={{ token }}" style="display:inline-block; padding:12px 28px; font-family:Arial, Helvetica, sans-serif; font-size:15px; font-weight:bold; color:#ffffff;">
                    Verify email
                  </a>
                </td>
              </tr>
            </table>
            <p style="margin:24px 0 0 0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#94a3b8;">
              Or copy and paste this link into your browser:<br />
              <span style="color:#2563eb; word-break:break-all;">https://app.rentifyx.com/verify-email?token={{ token }}</span>
            </p>
          </td>
        </tr>

        <tr>
          <td style="background-color:#ffffff; padding:0 40px 32px 40px; border-left:1px solid #e2e8f0; border-right:1px solid #e2e8f0; border-radius:0 0 8px 8px; border-bottom:1px solid #e2e8f0;" class="mobile-px-24">
            <p style="margin:0; font-family:Arial, Helvetica, sans-serif; font-size:13px; line-height:20px; color:#94a3b8;">
              This link expires soon for your security. If you didn't create a RentifyX account, you can ignore this email.
            </p>
          </td>
        </tr>
      </table>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:24px auto 0 auto;">
        <tr>
          <td align="center" style="padding:0 40px;" class="mobile-px-24">
            <p style="margin:0 0 4px 0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:18px; color:#94a3b8; text-align:center;">
              RentifyX &middot; This is a transactional message related to your account.
            </p>
            <p style="margin:0; font-family:Arial, Helvetica, sans-serif; font-size:12px; line-height:18px; color:#94a3b8; text-align:center;">
              &copy; RentifyX. All rights reserved.
            </p>
          </td>
        </tr>
      </table>

    </div>
    <!--[if mso]>
    </td></tr></table>
    <![endif]-->
  </center>
</body>
</html>
