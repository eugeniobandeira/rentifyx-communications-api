{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "OpenApi": {
    "ContactName": "eugeniobandeira",
    "ContactUrl": "https://github.com/eugeniobandeira"
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "Consent": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Kafka": {
    "ConsumerGroupId": "rentifyx-communications-api"
  },
  "DynamoDb": {
    "NotificationsTableName": "notifications"
  },
  "Resilience": {
    "TokenBucketPermitsPerSecond": 14,
    "TokenBucketQueueMaxWaitSeconds": 5,
    "CircuitBreakerMinimumThroughput": 5,
    "CircuitBreakerSamplingDurationSeconds": 30,
    "CircuitBreakerBreakDurationSeconds": 30
  },
  "Reconciliation": {
    "PollIntervalSeconds": 60,
    "StalenessThresholdSeconds": 120
  },
  "SecretsProvider": {
    "SesArn": "rentifyx/comms/ses-arn",
    "KafkaSaslUsername": "rentifyx/comms/kafka-sasl-username",
    "KafkaSaslPassword": "rentifyx/comms/kafka-sasl-password",
    "ApiKey": "rentifyx/comms/api-key"
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": ""
}
